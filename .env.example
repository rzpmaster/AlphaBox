# Docker Compose host ports. Change these if the host already uses a port.
FRONTEND_PORT=3000
BACKEND_PORT=8000
# Postgres and Redis are internal by default. These are used by docker-compose.dev.yml only.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Browser-facing frontend config. Keep this relative when serving through Nginx.
PUBLIC_ORIGIN=https://alphabox.breezerong.cn
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_TIME_ZONE=UTC+8

# Server-side Next.js rewrite target. In Docker Compose, use the backend service name.
INTERNAL_API_URL=http://backend:8000

# Backend config.
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Add every browser origin that may call the backend directly.
# Relative /api requests through Nginx normally only need PUBLIC_ORIGIN.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://alphabox.breezerong.cn

# Container-to-container services use compose service names below.
POSTGRES_DB=alphabox
POSTGRES_USER=alphabox
POSTGRES_PASSWORD=alphabox

# Initial admin.
CREATE_INITIAL_ADMIN=true
INITIAL_ADMIN_EMAIL=admin@alphabox.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_DISPLAY_NAME=AlphaBox Admin
